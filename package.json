{
  "name": "frontend-web-applications",
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "bdd": "cucumber-js e2e-bdd/features/**/*.feature",
    "bdd:services": "cucumber-js e2e-bdd/features/services.feature --tags @services",
    "bdd:services:dry-run": "cucumber-js e2e-bdd/features/services.feature --require-module ts-node/register --require e2e-bdd/support/**/*.ts --require e2e-bdd/steps/**/*.ts --dry-run",
    "bdd:iam": "cucumber-js e2e-bdd/features/iam.feature --tags @iam",
    "bdd:iam:dry-run": "cucumber-js e2e-bdd/features/iam.feature --require-module ts-node/register --require e2e-bdd/support/**/*.ts --require e2e-bdd/steps/**/*.ts --dry-run",
    "bdd:profiles": "cucumber-js e2e-bdd/features/profiles.feature --tags @profiles",
    "bdd:profiles:dry-run": "cucumber-js e2e-bdd/features/profiles.feature --require-module ts-node/register --require e2e-bdd/support/**/*.ts --require e2e-bdd/steps/**/*.ts --dry-run",
    "build:gh-pages": "ng build --configuration production --base-href \"/Frontend-Web-Applications/\"",
    "deploy:gh-pages": "npx angular-cli-ghpages --dir=dist/frontend-web-applications/browser"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^19.2.15",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/material": "^19.2.15",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@fullcalendar/angular": "^6.1.17",
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/timegrid": "^6.1.17",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@stripe/stripe-js": "^7.4.0",
    "@tsparticles/angular": "^3.0.0",
    "@tsparticles/engine": "^3.8.1",
    "ng-carousel-cdk": "^2.1.0",
    "ngx-owl-carousel-o": "^19.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "tsparticles": "^3.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.10",
    "@angular/cli": "^19.2.10",
    "@angular/compiler-cli": "^19.2.0",
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^25.6.0",
    "angular-cli-ghpages": "^2.0.3",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2"
  }
}
